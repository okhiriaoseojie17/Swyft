{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/send",        "destination": "/send.html" },
    { "source": "/receive",     "destination": "/receive.html" },
    { "source": "/online-home", "destination": "/online-home.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
